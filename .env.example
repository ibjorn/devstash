# Neon PostgreSQL
# Pooled connection (hostname contains "-pooler") — used by the app at runtime
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/devstash?sslmode=require"
# Direct connection (no "-pooler") — used by Prisma CLI for migrations
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/devstash?sslmode=require"
